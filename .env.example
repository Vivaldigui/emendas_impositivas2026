DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=verify-full"
COLETA_ADMIN_SECRET=
CRON_SECRET=
SONNER_EMPENHOS_ENDPOINT=
# --- IA (Google Gemini) ---
GEMINI_API_KEY=
GEMINI_EMPENHO_MODEL=gemini-2.5-flash
IA_EMPENHO_ENABLED=true
OPENAI_EMPENHO_TIMEOUT_MS=18000
OPENAI_EMPENHO_MAX_RETRIES=1

# --- Login do painel admin (opcionais) ---
# SESSION_SECRET: chave para assinar o cookie de sessao. Se vazio, usa
# COLETA_ADMIN_SECRET. Defina um valor proprio e longo em producao.
SESSION_SECRET=
# ADMIN_USERS: lista de logins nomeados (melhora a auditoria). Se vazio,
# o login aceita qualquer usuario com a senha = COLETA_ADMIN_SECRET.
# Exemplo: [{"usuario":"joao","senha":"trocar-isto","nome":"Joao Silva"}]
ADMIN_USERS=
