generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Vereador {
  id        String   @id
  nome      String
  nomeCurto String
  partido   String?
  foto      String
  emendas   Emenda[]
}

model Emenda {
  id              String                 @id
  vereadorId      String
  vereador        Vereador               @relation(fields: [vereadorId], references: [id])
  descricao       String                 @db.Text
  valorAutorizado Decimal                @db.Decimal(16, 2)
  area            String
  secretaria      String
  codigo          String?
  acao            String?
  dotacao         String?
  fonteDocumento  String
  vinculos        EmendaEmpenhoVinculo[]
  analisesIa      AnaliseIaEmenda[]

  @@index([vereadorId])
  @@index([area])
  @@index([acao])
}

model Empenho {
  id                String                 @id
  ano               Int
  numeroEmpenho     String?
  dataEmpenho       DateTime?
  fornecedor        String?
  cnpjCpfFornecedor String?
  historico         String?                @db.Text
  secretaria        String?
  dotacao           String?
  ficha             String?
  processoCompra    String?
  valorEmpenhado    Decimal                @default(0) @db.Decimal(16, 2)
  valorLiquidado    Decimal                @default(0) @db.Decimal(16, 2)
  valorPago         Decimal                @default(0) @db.Decimal(16, 2)
  situacao          String?
  fonte             String
  hashArquivo       String?
  linhaBruta        Json?
  vinculos          EmendaEmpenhoVinculo[]

  @@index([ano, numeroEmpenho])
  @@index([fornecedor])
  @@index([dotacao])
}

model EmendaEmpenhoVinculo {
  id                  String                   @id @default(cuid())
  emendaId            String
  emenda              Emenda                   @relation(fields: [emendaId], references: [id], onDelete: Cascade)
  empenhoId           String
  empenho             Empenho                  @relation(fields: [empenhoId], references: [id], onDelete: Cascade)
  criterio            String
  confianca           Decimal?                 @db.Decimal(5, 2)
  observacao          String                   @db.Text
  valorAtribuido      Decimal?                 @db.Decimal(16, 2)
  origem              String                   @default("REGRA")
  decisao             String                   @default("SUGERIDO")
  criterios           String[]                 @default([])
  justificativaCurta  String?                  @db.Text
  camposUsados        String[]                 @default([])
  modelo              String?
  promptVersion       String?
  inputHash           String?
  criadoEm            DateTime                 @default(now())
  atualizadoEm        DateTime                 @default(now()) @updatedAt
  revisadoEm          DateTime?
  revisadoPor         String?
  revisoes            EmendaEmpenhoRevisao[]

  @@unique([emendaId, empenhoId])
  @@index([criterio])
  @@index([decisao])
  @@index([origem])
  @@index([inputHash])
}

model AnaliseIaEmenda {
  id                   String   @id @default(cuid())
  emendaId             String
  emenda               Emenda   @relation(fields: [emendaId], references: [id], onDelete: Cascade)
  resultadoGeral       String
  dataAnalise          DateTime @default(now())
  modelo               String?
  promptVersion        String?
  inputHash            String
  quantidadeCandidatos Int
  justificativa        String?  @db.Text
  erro                 String?  @db.Text
  tokensEntrada        Int?
  tokensEntradaCache   Int?
  tokensSaida          Int?
  tokensTotal          Int?
  custoEstimadoUsd     Decimal? @db.Decimal(12, 6)

  @@unique([emendaId, inputHash])
  @@index([resultadoGeral])
  @@index([dataAnalise])
  @@index([modelo, dataAnalise])
}

model EmendaEmpenhoRevisao {
  id                String                @id @default(cuid())
  vinculoId         String
  vinculo           EmendaEmpenhoVinculo  @relation(fields: [vinculoId], references: [id], onDelete: Cascade)
  emendaId          String
  empenhoId         String
  situacaoAnterior  String
  situacaoNova      String
  valorAnterior     Decimal?              @db.Decimal(16, 2)
  valorNovo         Decimal?              @db.Decimal(16, 2)
  justificativa     String?               @db.Text
  revisadoPor       String
  revisadoEm        DateTime              @default(now())

  @@index([vinculoId])
  @@index([emendaId])
  @@index([empenhoId])
  @@index([revisadoEm])
}

model ColetaEmpenhosArquivo {
  id              String   @id @default(cuid())
  inicio          DateTime
  fim             DateTime
  formato         String
  fonte           String
  endpoint        String?
  parametrosJson  Json
  hashArquivo     String   @unique
  caminhoArquivo  String
  contentType     String?
  dataColeta      DateTime @default(now())
  status          String
  erro            String?
  registrosBrutos Int      @default(0)
  registrosImportados Int  @default(0)

  @@index([inicio, fim])
  @@index([dataColeta])
}

model ColetaLog {
  id          String   @id @default(cuid())
  coletor     String
  status      String
  inicioEm    DateTime @default(now())
  fimEm       DateTime?
  mensagem    String?
  erro        String?  @db.Text
  metadados   Json?

  @@index([coletor, status])
  @@index([inicioEm])
}
